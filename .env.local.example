# Frontend env example for Crypto Journal (do NOT commit secrets to VCS)
# Replace values and save as .env.local in the 'crypto-journal-front' folder

NEXT_PUBLIC_BACKEND_URL=http://3.36.109.46.nip.io:8080
NEXT_PUBLIC_BASE_URL=http://3.36.109.46:3000

# Google OAuth (register exact redirect URI in Google Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://3.36.109.46.nip.io:3000/google/callback

# Naver OAuth
NEXT_PUBLIC_NAVER_CLIENT_ID=your-naver-client-id
NEXT_PUBLIC_NAVER_REDIRECT_URI=http://3.36.109.46:3000/naver/callback

# Kakao OAuth
NEXT_PUBLIC_KAKAO_CLIENT_ID=your-kakao-rest-api-key
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://3.36.109.46:3000/kakao/callback

